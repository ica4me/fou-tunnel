# ══════════════════════════════════════════════
#  FOU TUNNEL — CLIENT
#  Interface  : eth2
#  IP Lokal   : 172.16.3.200  (bind lokal)
#  IP Publik  : 38.47.95.247  (CGNAT/NAT keluar)
# ══════════════════════════════════════════════

# ── Interface & IP lokal client ───────────────
CLIENT_IFACE=eth2
CLIENT_LOCAL_IP=172.16.3.200
CLIENT_PUBLIC_IP=38.47.95.247    # informasi saja (tidak di-bind)

# ── Server (tujuan tunnel) ────────────────────
SERVER_IP=202.10.48.182

# ── FOU Encapsulation ─────────────────────────
FOU_PORT=5555
IPPROTO=4                        # 4=IPIP | 47=GRE
TUNNEL_PROTO=ipip

# ── Interface tunnel virtual ──────────────────
TUNNEL_IF=tun0
TUNNEL_CLIENT_ADDR=10.11.12.2/30
TUNNEL_SERVER_PEER=10.11.12.1

# ── Keepalive (KRITIS untuk CGNAT) ───────────
# CGNAT drop UDP idle setelah ~30 detik
# Set interval < 30 detik
ENABLE_KEEPALIVE=true
KEEPALIVE_INTERVAL=20

# ── Routing ───────────────────────────────────
# Semua traffic lewat VPS? (full tunnel)
ADD_DEFAULT_ROUTE=false

# Route spesifik, pisah koma:
# contoh: 192.168.50.0/24,10.0.0.0/8
ADD_CUSTOM_ROUTES=
